---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Problema from '../components/Problema.astro';
import Solucao from '../components/Solucao.astro';
import Motor from '../components/Motor.astro';
import Gestao from '../components/Gestao.astro';
import Campo from '../components/Campo.astro';
import QuemFez from '../components/QuemFez.astro';
import CtaFinal from '../components/CtaFinal.astro';
import FAQ from '../components/FAQ.astro';
import Footer from '../components/Footer.astro';
---
<Layout>
  <a href="#conteudo-principal" class="skip-link">Ir para o conteúdo principal</a>
  <Nav />
  <main id="conteudo-principal">
    <Hero />
    <QuemFez />
    <Problema />
    <Solucao />
    <Motor />
    <Gestao />
    <Campo />
    <FAQ />
    <CtaFinal />
  </main>
  <Footer />
</Layout>

<script>
  import { initLogoAnimations } from '../scripts/logo-animation';
  initLogoAnimations();
</script>
