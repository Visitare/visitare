---
import LogoSymbol from './LogoSymbol.astro';
import LogoType from './LogoType.astro';
---
<footer class="bg-primary-dark text-white">
  <div class="h-[3px] bg-secondary"></div>
  <div class="max-w-[1100px] mx-auto px-6 py-12 flex justify-between items-end flex-wrap gap-6">

    <div>
      <a href="/" class="logo-lockup inline-flex items-center gap-3 no-underline py-1">
        <LogoSymbol height={36} variant="dark" />
        <LogoType height={26} variant="dark" />
      </a>
      <p class="text-[14px] text-white/55 mt-2.5 font-mono tracking-[0.02em]">
        AGENTE COMUNITÁRIO DE SAÚDE · RIO DE JANEIRO · 2026
      </p>
    </div>

    <div class="font-mono text-[12px] text-white/40 text-right leading-[1.8]">
      Portaria SAS/MS 221/2008 · Manual ACS-MS<br />
      Carteira APS SMS-Rio 2021 · PNAB 2017<br />
      Claude Impact Lab Rio
    </div>

  </div>
</footer>
