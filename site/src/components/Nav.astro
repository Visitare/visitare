---
import LogoSymbol from './LogoSymbol.astro';
import LogoType from './LogoType.astro';
---
<nav class="bg-primary-dark border-b-2 border-secondary sticky top-0 z-50 py-3.5">
  <div class="max-w-[1100px] mx-auto px-6 flex items-center justify-between">

    <a href="/" class="logo-lockup flex items-start gap-3 no-underline py-2" aria-label="Visitare — página inicial">
      <LogoSymbol height={36} variant="dark" />
      <LogoType height={26} variant="dark" />
    </a>

    <div class="flex items-center gap-1">
      <a href="#problema" class="nav-link text-[15px] text-white/70 no-underline font-medium transition-colors hover:text-white hidden md:flex items-center px-3 py-3">O problema</a>
      <a href="#solucao"  class="nav-link text-[15px] text-white/70 no-underline font-medium transition-colors hover:text-white hidden md:flex items-center px-3 py-3">A solução</a>
      <a href="#motor"    class="nav-link text-[15px] text-white/70 no-underline font-medium transition-colors hover:text-white hidden md:flex items-center px-3 py-3">Motor</a>
      <a href="#quem-fez" class="nav-link text-[15px] text-white/70 no-underline font-medium transition-colors hover:text-white hidden md:flex items-center px-3 py-3">Quem fez</a>
      <a
        href="/demo"
        class="ml-2 text-[15px] font-semibold bg-tertiary text-on-tertiary rounded-lg px-5 no-underline transition-opacity hover:opacity-90 inline-flex items-center gap-2"
        style="min-height:44px;padding-block:10px"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="17" r="1"/></svg>
        Ver demo
      </a>
    </div>

  </div>
</nav>
