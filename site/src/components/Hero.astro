---
---
<header class="hero relative overflow-hidden text-white pt-20 pb-22 border-t-0"
  style="background: linear-gradient(158deg, #00565E 0%, #006D77 55%, #007B85 100%);">

  <!-- overlay coral -->
  <div class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(700px 350px at 90% 0%, rgba(198,107,79,.22), transparent 60%);">
  </div>

  <div class="relative z-10 max-w-[1100px] mx-auto px-6">

    <p class="inline-flex items-center gap-2 font-mono text-[11px] tracking-[0.08em] font-medium bg-white/10 border border-white/20 px-3 py-1.5 rounded text-white/90 mb-7">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2" stroke-linecap="round"/></svg>
      Claude Impact Lab Rio · SMS-Rio · 2026
    </p>

    <h1 class="font-semibold leading-[1.05] tracking-[-0.03em] mb-[22px] max-w-[16ch]"
      style="font-size: clamp(36px, 5.2vw, 60px)">
      O agente de saúde que cuida de todo mundo merece uma ferramenta
      <em class="not-italic" style="color: #E8C4B8"> à altura.</em>
    </h1>

    <p class="max-w-[50ch] text-white/88 mb-10 leading-[1.65]" style="font-size: clamp(16px,1.8vw,19px)">
      Visitare é o copiloto dos Agentes Comunitários de Saúde — colocando a ficha clínica,
      a lista de visitas e o histórico do paciente direto no celular, na porta de casa.
    </p>

    <div class="flex gap-3.5 flex-wrap mb-16">
      <a href="/demo" class="btn-primary inline-flex items-center gap-2.5 bg-primary text-on-primary font-semibold text-base px-8 py-4 rounded-lg no-underline transition-all hover:-translate-y-0.5"
        style="box-shadow: 0 10px 28px -10px rgba(0,109,119,.5)">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="17" r="1"/></svg>
        Ver o produto
      </a>
      <a href="https://wa.me/5524992679147" target="_blank" rel="noopener"
        class="inline-flex items-center gap-2.5 text-white/90 border border-white/30 rounded-lg px-7 py-[15px] font-medium text-[15px] no-underline transition-all hover:bg-white/8 hover:border-white/50">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Mais informações
      </a>
    </div>

    <!-- Métricas de impacto -->
    <div class="grid grid-cols-3 border border-white/18 rounded-lg overflow-hidden bg-white/5 max-sm:grid-cols-1">
      <div class="px-7 py-6 border-r border-white/15 max-sm:border-r-0 max-sm:border-b">
        <div class="font-mono font-semibold leading-none tracking-[-0.03em]" style="font-size: clamp(28px,3.8vw,44px)">6.200</div>
        <div class="text-[13px] text-white/78 mt-2.5 leading-[1.45]">agentes comunitários no Rio de Janeiro</div>
      </div>
      <div class="px-7 py-6 border-r border-white/15 max-sm:border-r-0 max-sm:border-b">
        <div class="font-mono font-semibold leading-none tracking-[-0.03em]" style="font-size: clamp(28px,3.8vw,44px)">
          1<small class="text-[0.46em] font-medium opacity-75 tracking-normal">h/dia</small>
        </div>
        <div class="text-[13px] text-white/78 mt-2.5 leading-[1.45]">recuperada de papelada por agente</div>
      </div>
      <div class="px-7 py-6">
        <div class="font-mono font-semibold leading-none tracking-[-0.03em]" style="font-size: clamp(28px,3.8vw,44px)">
          1,5<small class="text-[0.46em] font-medium opacity-75 tracking-normal"> mi</small>
        </div>
        <div class="text-[13px] text-white/78 mt-2.5 leading-[1.45]">de horas por ano devolvidas ao cuidado</div>
      </div>
    </div>

  </div>
</header>
