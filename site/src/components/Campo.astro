---
import SectionLabel from './SectionLabel.astro';

const cards = [
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12.55a11 11 0 0114 0" stroke-linecap="round"/><line x1="2" y1="2" x2="22" y2="22" stroke-linecap="round"/></svg>`,
    title: 'Funciona sem sinal',
    body: 'Salva no aparelho primeiro, sincroniza quando o sinal volta. Sem perder dado, sem culpar o agente.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="5" y="2" width="14" height="20" rx="2"/><circle cx="12" cy="17" r="1"/></svg>`,
    title: 'Só precisa do celular',
    body: 'Nenhuma dependência de PC na clínica. O agente resolve tudo no campo, onde o paciente está.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4l3 2" stroke-linecap="round"/></svg>`,
    title: 'Uma tela, uma tarefa',
    body: 'Interface simples e direta — legível no sol, operável com uma mão, rápida mesmo em Android de entrada.',
  },
  {
    icon: `<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M4 20c0-4 4-6 8-6s8 2 8 6" stroke-linecap="round"/></svg>`,
    title: 'Amplifica, não substitui',
    body: 'O vínculo humano entre o agente e a família é insubstituível. O app cuida da burocracia para a Claudia cuidar das pessoas.',
  },
];
---
<section id="campo" class="py-22 border-t border-surface-container">
  <div class="max-w-[1100px] mx-auto px-6">
    <SectionLabel number="04" label="Construído para o campo" />
    <h2 class="font-semibold mt-3.5 mb-3 leading-[1.1] tracking-[-0.02em] text-primary-dark" style="font-size: clamp(26px,3.2vw,38px)">
      Feito pra rua, pro sol, pro morro.
    </h2>
    <p class="text-on-surface-variant max-w-[60ch] text-[17px] mb-10 leading-[1.65]">
      O Visitare não foi projetado para um escritório. Foi projetado para a Rocinha — e para toda comunidade com conexão intermitente e agentes trabalhando com uma mão só, com pressa.
    </p>

    <div class="grid grid-cols-2 gap-4 max-md:grid-cols-1">
      {cards.map((c) => (
        <div class="bg-white border border-surface-container-high rounded-lg p-6 shadow-sm flex gap-[18px] items-start">
          <div class="w-10 h-10 rounded-[9px] bg-tertiary/10 text-tertiary grid place-items-center shrink-0" set:html={c.icon} />
          <div>
            <h4 class="text-[16px] font-semibold text-primary-dark mb-1.5">{c.title}</h4>
            <p class="text-[15px] text-on-surface-variant leading-[1.55]">{c.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
