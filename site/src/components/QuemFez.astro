---
import SectionLabel from './SectionLabel.astro';

const badges = ['SMS-Rio', 'Claude Impact Lab', 'Médica na equipe', 'Escuta com ACS', 'Rocinha'];
---
<section id="quem-fez" class="py-10 border-t border-surface-container">
  <div class="max-w-[1100px] mx-auto px-6">
    <SectionLabel label="Origem" />

    <div class="mt-5 border border-surface-container-high rounded-lg overflow-hidden bg-white shadow-sm">
      <div class="grid grid-cols-[1fr_auto] items-center gap-8 px-8 py-7 max-md:grid-cols-1 max-md:gap-5">

        <div>
          <p class="text-[17px] font-semibold text-primary-dark mb-1.5">
            Pilotado com a Secretaria Municipal de Saúde do Rio de Janeiro.
          </p>
          <p class="text-[15px] text-on-surface-variant leading-[1.6]">
            Construído no Claude Impact Lab Rio com ACS reais na Rocinha. Médica, designers e engenheiros. Código aberto.
          </p>
        </div>

        <div class="flex flex-wrap gap-2 shrink-0 max-md:w-full">
          {badges.map((b) => (
            <span class="inline-flex items-center font-mono text-[12px] font-semibold px-3 py-1.5 rounded bg-surface-container text-primary-dark border border-surface-container-high tracking-[0.04em] whitespace-nowrap">
              {b}
            </span>
          ))}
        </div>

      </div>
    </div>
  </div>
</section>
