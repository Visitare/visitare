---
import '../styles/globals.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Visitare — O copiloto do Agente Comunitário de Saúde',
  description = 'Visitare digitaliza as visitas domiciliares dos ACS: lista priorizada de famílias no celular, funciona offline, envia dados ao SISAB sem retrabalho. Parceria SMS-Rio.',
  ogImage = 'https://visitare.app/og-image.png',
} = Astro.props;

const canonicalUrl = `https://visitare.app${Astro.url.pathname}`;
const url = Astro.url.href;
---
<!doctype html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="description" content={description} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={url} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Canônica (S-004) -->
  <link rel="canonical" href={canonicalUrl} />

  <!-- JSON-LD: SoftwareApplication + Organization (S-001 / GEO) -->
  <script type="application/ld+json" set:html={JSON.stringify([
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Visitare",
      "description": "Aplicativo mobile para Agentes Comunitários de Saúde (ACS) do SUS. Digitaliza visitas domiciliares, entrega lista priorizada de famílias no celular do agente, funciona offline e envia dados automaticamente ao SISAB. Desenvolvido com a Secretaria Municipal de Saúde do Rio de Janeiro.",
      "applicationCategory": "HealthApplication",
      "operatingSystem": "Android",
      "inLanguage": "pt-BR",
      "audience": {
        "@type": "Audience",
        "audienceType": "Secretarias Municipais de Saúde, gestores de Atenção Primária à Saúde"
      },
      "creator": {
        "@type": "Organization",
        "name": "Claude Impact Lab Rio",
        "url": "https://visitare.app"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "Visitare",
      "url": "https://visitare.app",
      "description": "Ferramenta de gestão de visitas domiciliares para ACS do SUS, desenvolvida em parceria com a SMS-Rio.",
      "foundingLocation": { "@type": "Place", "name": "Rio de Janeiro, Brasil" },
      "contactPoint": {
        "@type": "ContactPoint",
        "contactType": "sales",
        "availableLanguage": "Portuguese"
      }
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        { "@type": "Question", "name": "O Visitare funciona sem internet?", "acceptedAnswer": { "@type": "Answer", "text": "Sim. O Visitare é offline-first: salva todos os dados no celular do agente durante a visita e sincroniza automaticamente quando o sinal volta." } },
        { "@type": "Question", "name": "Como o Visitare se integra ao SISAB e ao Vitacare?", "acceptedAnswer": { "@type": "Answer", "text": "As fichas preenchidas pelo agente chegam prontas ao SISAB sem digitação manual na clínica. A integração com o Vitacare sincroniza o histórico familiar em tempo real." } },
        { "@type": "Question", "name": "O agente precisa de smartphone novo?", "acceptedAnswer": { "@type": "Answer", "text": "Não. O Visitare roda em Android de entrada, inclusive em aparelhos de baixo custo amplamente usados por ACS." } },
        { "@type": "Question", "name": "O Visitare está em conformidade com a LGPD?", "acceptedAnswer": { "@type": "Answer", "text": "Sim. Todas as visitas são auditáveis e a sincronização é cifrada, alinhado às portarias do Ministério da Saúde." } },
        { "@type": "Question", "name": "Quem desenvolveu o Visitare?", "acceptedAnswer": { "@type": "Answer", "text": "Construído no Claude Impact Lab Rio com a Secretaria Municipal de Saúde do Rio de Janeiro, com escuta direta de ACS da Rocinha. Código aberto." } }
      ]
    }
  ])} />

  <!-- Fontes: Merriweather Sans (corpo/títulos) + DM Mono (números/dados). -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Merriweather+Sans:ital,wght@0,300;0,400;0,600;0,700;0,800;1,300;1,400&family=DM+Mono:ital,wght@0,300;0,400;0,500;1,300;1,400;1,500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <slot />
</body>
</html>

